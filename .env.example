# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
NEXT_PUBLIC_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_PLACES_API_KEY: Required for Google Places API calls (server-side only).
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable: Places API, Geocoding API, Maps JavaScript API
GOOGLE_PLACES_API_KEY="MY_GOOGLE_PLACES_API_KEY"

# GOOGLE_MAPS_API_KEY: Required for Google Maps embed functionality.
# Can be the same as GOOGLE_PLACES_API_KEY
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="MY_GOOGLE_MAPS_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
NEXT_PUBLIC_APP_URL="MY_APP_URL"

# EMAIL CONFIGURATION (for future Zoho/Nodemailer integration)
EMAIL_SERVICE="zoho"
EMAIL_HOST="smtp.zoho.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@zoho.com"
EMAIL_PASS="your-app-password"
