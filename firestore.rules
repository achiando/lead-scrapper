// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: clinics
// Document ID: auto-generated
// Fields:
//   - name: string (required, 1-200 chars)
//   - category: string (optional, 1-100 chars)
//   - rating: number (optional, 0-5)
//   - reviewsCount: number (optional, >= 0)
//   - phone: string (optional, 1-20 chars)
//   - address: string (optional, 1-500 chars)
//   - websiteUrl: string (optional, valid URL)
//   - mapEmbedUrl: string (optional, valid URL)
//   - city: string (optional, 1-100 chars)
//   - createdAt: int (required, timestamp)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "achiandofrancline@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidClinic(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.createdAt is number &&
             (!('category' in data) || data.category == null || (data.category is string && data.category.size() <= 100)) &&
             (!('rating' in data) || data.rating == null || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
             (!('reviewsCount' in data) || data.reviewsCount == null || (data.reviewsCount is number && data.reviewsCount >= 0)) &&
             (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() <= 50)) &&
             (!('address' in data) || data.address == null || (data.address is string && data.address.size() <= 500)) &&
             (!('websiteUrl' in data) || data.websiteUrl == "" || data.websiteUrl == null || isValidUrl(data.websiteUrl)) &&
             (!('mapEmbedUrl' in data) || data.mapEmbedUrl == "" || data.mapEmbedUrl == null || isValidUrl(data.mapEmbedUrl)) &&
             (!('city' in data) || data.city == null || (data.city is string && data.city.size() <= 100)) &&
             (!('status' in data) || data.status == null || (data.status is string && data.status.size() <= 50)) &&
             (!('slug' in data) || data.slug == null || (data.slug is string && data.slug.size() <= 200)) &&
             (!('searchTerm' in data) || data.searchTerm == null || (data.searchTerm is string && data.searchTerm.size() <= 200)) &&
             (!('metaTitle' in data) || data.metaTitle == null || (data.metaTitle is string && data.metaTitle.size() <= 200)) &&
             (!('metaDescription' in data) || data.metaDescription == null || (data.metaDescription is string && data.metaDescription.size() <= 500));
    }

    match /clinics/{clinicId} {
      // Allow anyone to read clinics (for the demo sites)
      allow read: if true;
      
      // Only authenticated users can create/update/delete clinics
      allow create: if isAuthenticated() && isValidClinic(request.resource.data);
      allow update: if isAuthenticated() && isValidClinic(request.resource.data);
      allow delete: if isAuthenticated();
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}

// I've set up prototype Security Rules to keep the data in Firestore safe. 
// They are designed to be secure by requiring authentication for write operations 
// and validating the schema of the clinic documents. 
// However, you should review and verify them before broadly sharing your app. 
// If you'd like, I can help you harden these rules.

// ===============================================================
// Assessment: Security Validator (Red Team Edition)
